# =========================================================
# frontend/.env.example — Template for all variables
# Secrets (NEXTAUTH_SECRET, JWT_SECRET, GOOGLE_*) must NOT be
# committed with real values: use Jenkins Credentials in CI/CD.
# =========================================================

# ─── Environment ──────────────────────────────────────────
NODE_ENV=development

# ─── NextAuth ─────────────────────────────────────────────
# Points to the public URL exposed by Nginx on port 80
NEXTAUTH_URL=http://localhost:3001
# Minimum 32 characters — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=CHANGEME
AUTH_SESSION_MAX_AGE_HOURS=9

# ─── Backend API ──────────────────────────────────────────
# In staging/production this points to the public URL (Nginx).
# In Docker the server-side proxy uses this variable internally.
NEXT_PUBLIC_BACKEND_URL=http://localhost:3000
NEXT_PUBLIC_WS_URL=ws://localhost:3000

# ─── JWT ──────────────────────────────────────────────────
# Must match exactly the backend JWT_SECRET
JWT_SECRET=CHANGEME
JWT_EXPIRES_IN=9h

# ─── Cart ─────────────────────────────────────────────────
# CART orders expiration
NEXT_PUBLIC_CART_EXPIRATION_HOURS=24

# ─── Logging ──────────────────────────────────────────────
# Debug Logging (set to 'true' to enable debug logs)
NEXT_PUBLIC_DEBUG_LOGS=false
# Info Logging (set to 'true' to enable info logs)
NEXT_PUBLIC_INFO_LOGS=true

# ─── OAuth (optional) ─────────────────────────────────────
GOOGLE_CLIENT_ID=CHANGEME
GOOGLE_CLIENT_SECRET=CHANGEME
