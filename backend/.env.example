# =========================================================
# backend/.env.example — Template for all variables
# Copy to .env.development / .env.staging / .env.production
# and fill in the appropriate values.
# Secrets (JWT_SECRET, DB_PASSWORD, MONGODB_URI with password)
# must NOT be committed: use Jenkins Credentials in CI/CD.
# =========================================================

# ─── Environment ──────────────────────────────────────────
NODE_ENV=development

# ─── Server ───────────────────────────────────────────────
PORT=3000

# ─── MySQL Database ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=CHANGEME
DB_DATABASE=zenithstore

# SYNC=true ONLY in development (TypeORM auto-alter schema).
# In staging/production it must ALWAYS be false.
SYNC=false

LOGGING=false

# ─── MongoDB ──────────────────────────────────────────────
# Include user:password only in local development.
# In staging/production secrets are injected by Jenkins.
MONGODB_URI=mongodb://admin:CHANGEME@localhost:27018/zenithstore?authSource=admin

# ─── JWT ──────────────────────────────────────────────────
JWT_SECRET=CHANGEME
JWT_EXPIRES_IN=9h

# ─── Security ─────────────────────────────────────────────
ALLOWED_DOMAIN=localhost
CORS_ORIGIN=http://localhost,http://localhost:3000,http://localhost:3001

# ─── Rate Limiting ────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# ─── Logging ──────────────────────────────────────────────
ACCESS_LOG_FILE_NAME=access.log
ERROR_LOG_FILE_NAME=errors.log

# ─── Cart Cleanup Job ─────────────────────────────────────
CART_CLEANUP_INTERVAL_MINUTES=10    # Cleanup job execution interval
CART_EXPIRATION_HOURS=24            # CART orders expiration
RESERVED_EXPIRATION_HOURS=3         # RESERVED orders expiration
CART_GRACE_PERIOD_MINUTES=15        # Grace period to prevent race conditions